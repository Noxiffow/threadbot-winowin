{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ThreadBot API",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "Frontend (chat widget)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "3000", "--directory", "frontend"],
      "port": 3000
    }
  ]
}
